# Variables de entorno para desarrollo local

# Puerto del servidor
PORT=5000

# URL de la API (para desarrollo local, el frontend se conecta aquí)
REACT_APP_API_URL=http://localhost:5000/api

# Base de datos SQLite (ruta local, SQLite creará el archivo automáticamente)
DATABASE_URL=submissions.db

# Para producción en Railway, estas variables serán establecidas automáticamente
# Railway proporciona DATABASE_URL con credenciales de PostgreSQL
